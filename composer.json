{
    "name": "ceedcv-maya/shared-platform-laravel",
    "description": "Cross-cutting platform utilities for Laravel microservices: PostgreSQL FDW migrations helpers, locale providers, shared contracts.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Maya-AQSS/shared-platform-laravel",
    "support": {
        "issues": "https://github.com/Maya-AQSS/maya_platform/issues",
        "source": "https://github.com/Maya-AQSS/shared-platform-laravel"
    },
    "require": {
        "php": "^8.4",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/auth": "^11.0 || ^12.0 || ^13.0",
        "illuminate/broadcasting": "^11.0 || ^12.0 || ^13.0",
        "illuminate/cache": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/events": "^11.0 || ^12.0 || ^13.0",
        "illuminate/filesystem": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Maya\\Platform\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest --colors=always",
        "test-coverage": "pest --coverage --min=80"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maya\\Platform\\Providers\\SharedPlatformServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "laravel",
        "postgres",
        "fdw",
        "platform",
        "microservices",
        "ceedcv",
        "maya"
    ],
    "authors": [
        {
            "name": "CEEDCV",
            "email": "info@ceedcv.es",
            "homepage": "https://ceedcv.es"
        }
    ]
}

{
    "name": "ceedcv-maya/shared-platform-laravel",
    "description": "Cross-cutting platform utilities for Laravel microservices: PostgreSQL FDW migrations helpers, locale providers, shared contracts.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Maya-AQSS/shared-platform-laravel",
    "support": {
        "issues": "https://github.com/Maya-AQSS/maya_platform/issues",
        "source": "https://github.com/Maya-AQSS/shared-platform-laravel"
    },
    "require": {
        "php": "^8.4",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Maya\\Platform\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "laravel",
        "postgres",
        "fdw",
        "platform",
        "microservices",
        "ceedcv",
        "maya"
    ],
    "authors": [
        {
            "name": "CEEDCV",
            "email": "info@ceedcv.es",
            "homepage": "https://ceedcv.es"
        }
    ]
}
